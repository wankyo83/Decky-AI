# Model configs
GOOGLE_MODEL="gemini-3.5-flash" # Current stable Flash model.
GOOGLE_SEARCH_MODEL="gemini-2.5-flash" # Free tier supports Google Search grounding on this model.
ENABLE_GOOGLE_SEARCH=false # Keep false for the Gemini 3.5 free tier; search grounding is paid-only.
MODEL_TIMEOUT_SECONDS=60 # how long to wait for the model to respond before giving up and returning an error.
MODEL_TEMPERATURE=0.1 # how creative the model's responses will be. Higher values like 0.8 will make output more random, while lower values like 0.2 will make it more focused and deterministic.
NUM_HISTORY_MESSAGES=10 # how many recent messages to include in the prompt sent to the model
