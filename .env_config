# Model configs
GOOGLE_MODEL="gemma-4-26b-a4b-it" # Feel free to change to a different Gemini model.
MODEL_TIMEOUT_SECONDS=60 # how long to wait for the model to respond before giving up and returning an error.
MODEL_TEMP=0.1 # how creative the model's responses will be. Higher values like 0.8 will make output more random, while lower values like 0.2 will make it more focused and deterministic.
NUM_HISTORY_MESSAGES=5 # how many recent messages to include in the prompt sent to the model
